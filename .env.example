# Copy to .env.local (dev) or .env.production (prod):
#   cp .env.example .env.local
#   cp .env.example .env.production
#
# start.sh exports ASSETTO_ENV and ASSETTO_ENV_FILE for all services.

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# Stream keys (same for both services)
REDIS_STREAM_KEY=ac:events
REDIS_CONFIG_STREAM_KEY=ac:config
REDIS_STREAM_MAXLEN=200000
REDIS_SCHEMA_VERSION=1

# Instance ID (same for both Python and Node)
AC_INSTANCE_ID=vps-eu-1

# Server paths (comma-separated where noted in telemetry)
SERVERS_PATH=/home/jose/assetto-infra/server
TIME_ATTACK_SERVERS_PATH=/home/jose/assetto-install/assetto/server-timeattack
EVENTS_SERVERS_PATH=

# ac-data API
PORT=3000
API_KEY=
CORS_ORIGIN=http://localhost:3000
CONTENT_PATH=/home/jose/assetto-install/assetto/content

# Python telemetry settings
REDIS_CONFIG_CONSUMER_ENABLED=true
REDIS_CONFIG_CONSUMER_GROUP=ac-config-consumers
REDIS_CONFIG_CONSUMER_NAME=py-vps-eu-1
# Python only updates in-memory modes; ac-data writes INI and restarts AC servers
REDIS_CONFIG_INI_WRITE_ENABLED=false
LOG_LEVEL=INFO
REDIS_PUBLISH_QUEUE_SIZE=4096
REDIS_PUBLISH_WORKERS=1
# SKIP_LEGACY_SERVER_CFG=true

# Server pool (on-demand: 300 logical, few processes)
# SERVER_POOL_MODE=true          # only start AC when Convex isActive===true
# SERVER_POOL_ENABLED=true       # stop after idle minutes with zero players
# SERVER_POOL_IDLE_SHUTDOWN_MINUTES=15
# SERVER_POOL_TICK_MS=60000

# Server status throttling
SERVER_STATUS_POLL_INTERVAL_SEC=15
SERVER_STATUS_PUBLISH_INTERVAL_SEC=30
SERVER_STATUS_HEARTBEAT_INTERVAL_SEC=300
SERVER_STATUS_ON_CHANGE_ONLY=true
# CAR_INFO_SETTLE_MS=400
# GHOST_DRIVER_TIMEOUT_MS=90000

# Admin panel cookies (login). Use ADMIN_COOKIE_SECURE=true only behind HTTPS.
# SameSite=None requires Secure; default Lax works for http://host:3000/admin
# ADMIN_COOKIE_SECURE=false
# ADMIN_COOKIE_SAMESITE=lax

# Convex Cloud (get from https://convex.cloud dashboard)
CONVEX_DEPLOYMENT_URL=https://your-deployment.convex.cloud
CONVEX_PRODUCT_KEY=dev:your-deployment|your-key-here
CONVEX_WORKER_SECRET=your-worker-secret
CONVEX_INGEST_SECRET=your-ingest-secret

# ac-data Redis → Convex ingest batching (align with Convex WORKER_INGEST_MAX_BATCH_SIZE)
# WORKER_INGEST_MAX_BATCH_SIZE=64
# WORKER_INGEST_FLUSH_INTERVAL_MS=5000
# REDIS_INGEST_READ_COUNT=64

# HUD cache (Convex → Redis → /hud/* HTTP)
HUD_CACHE_SYNC_ENABLED=true
# Fallback reconciliation only; lap events refresh Redis via debounced worker queries
HUD_CACHE_SYNC_INTERVAL_MS=120000
HUD_CACHE_SYNC_SKIP_AFTER_LAP_MS=90000
HUD_LAP_REFRESH_DEBOUNCE_MS=1500
HUD_LAP_REFRESH_DELAY_MS=400
HUD_VER_TTL_SEC=3600
HUD_LB_TTL_SEC=300
HUD_PLAYER_TTL_SEC=300
HUD_RATE_LIMIT_MAX=30
# Optional: clients with X-API-Key matching HUD_API_KEY get a higher per-steamId/IP limit
HUD_RATE_LIMIT_AUTH_MAX=120
HUD_API_KEY=
HUD_CORS_ORIGIN=*
# Poll GET /hud/version (Redis-only) instead of /hud/session to detect new lap times
CONVEX_HUD_VERSION_QUERY=hud:getHudSnapshotVersion
CONVEX_HUD_SNAPSHOTS_QUERY=hud:getHudSnapshotsForWorker
CONVEX_HUD_TOP10_QUERY=hud:getHudTop10
CONVEX_HUD_PLAYER_QUERY=hud:getHudPlayer
CONVEX_HUD_SESSION_QUERY=hud:getHudSession

# Battle / touge tuning
BATTLE_ARM_MAX_GAP_METERS=15
BATTLE_ARM_MIN_SPEED_KMH=40
BATTLE_ARM_SUSTAINED_PROXIMITY_SEC=5
BATTLE_FINISHED_COOLDOWN_SEC=20
BATTLE_MIN_LAP_PROGRESS_BEFORE_FINISH=0.30
BATTLE_FINISH_POINT_MIN_GAP_METERS=20
BATTLE_DISAPPEAR_GAP_METERS=250
BATTLE_ABANDON_STALL_SEC=5
BATTLE_ABANDON_MIN_PROGRESS_METERS=200
BATTLE_OVERTAKE_MAX_GAP_FALLBACK_METERS=20
BATTLE_SPLINE_STUCK_SEC=2
BATTLE_SPLINE_STUCK_MIN_SPEED_KMH=25
BATTLE_SPLINE_MIN_MOVE_METERS=5
BATTLE_POSITION_AHEAD_MIN_METERS=2
BATTLE_DEFAULT_WIN_MIN_POINTS=2
OVERTAKE_MAX_GAP_METERS=15
OVERTAKE_POINT_COOLDOWN_SEC=2.0
COLLISION_MAX_GAP_METERS=25
BATTLE_COLLISION_WARN_COOLDOWN_SEC=4.0
