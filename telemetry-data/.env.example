# Identifies this VPS instance in Convex / Redis routing
AC_INSTANCE_ID=vps-eu-1

# AC server folders (paths containing cfg/server_cfg.ini), comma-separated
SERVERS_PATH=
TIME_ATTACK_SERVERS_PATH=
EVENTS_SERVERS_PATH=

# ── Redis (single source of truth for events and config) ──
REDIS_HOST=redis-xxxx.cxx.region.provider.com
REDIS_PORT=12827
REDIS_USERNAME=default
REDIS_PASSWORD=tu_password
REDIS_DB=0
REDIS_SSL=false
REDIS_STREAM_KEY=ac:events
REDIS_CONFIG_STREAM_KEY=ac:config
# Bound the stream size so it never grows past ~MAXLEN entries. With the
# on-change publish strategy this can be small. ~20000 entries x ~400 bytes
# ~= 8 MB worst case; tune lower if you are tight on Redis storage.
REDIS_STREAM_MAXLEN=20000
REDIS_SCHEMA_VERSION=1

# Redis config consumer (applies server_cfg.ini snapshots from Convex)
REDIS_CONFIG_CONSUMER_ENABLED=true
REDIS_CONFIG_CONSUMER_GROUP=ac-config-consumers
REDIS_CONFIG_CONSUMER_NAME=py-vps-eu-1

# ── Server status loop ──
# Local UDP poll cadence to clean up ghost drivers (no Redis cost).
# SERVER_STATUS_POLL_INTERVAL_SEC=15
# How often to publish a server_status to Redis when the snapshot CHANGED.
# SERVER_STATUS_PUBLISH_INTERVAL_SEC=30
# Force a "still alive" publish even if nothing changed (for liveness in Convex).
# SERVER_STATUS_HEARTBEAT_INTERVAL_SEC=300
# When false, every poll tick publishes a server_status (legacy behaviour).
# SERVER_STATUS_ON_CHANGE_ONLY=true
# Settle window for CAR_INFO sweeps before purging timed-out drivers.
# CAR_INFO_SETTLE_MS=400
# Stale window before considering a driver a ghost.
# GHOST_DRIVER_TIMEOUT_MS=90000

# ── Battle tuning ──
# Battle mode never kicks players nor restarts the AC session. When a pair
# exceeds MAX_BATTLE_GAP_METERS, has a false start, etc. we just silently go
# back to IDLE and wait for the next valid arming.
# BATTLE_SINGLE_SESSION_POINTS_MODE=true
# BATTLE_FINISH_POINT_MIN_GAP_METERS=50
# BATTLE_DISAPPEAR_GAP_METERS=250
# BATTLE_DEFAULT_WIN_MIN_POINTS=2
# OVERTAKE_POINT_COOLDOWN_SEC=2.0
# OVERTAKE_MIN_GAP_METERS=10
# BATTLE_COLLISION_WARN_COOLDOWN_SEC=4.0
# BATTLE_PRESTART_GAP_ABORT_GRACE_SEC=2.0
# BATTLE_GAP_ABORT_MIN_BOTH_SPEED_KMH=20.0
